{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "./bin/rails server -b 0.0.0.0",
    "healthcheckPath": "/up",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE"
  }
}
